#Executing this lablog will create the script _01_quast.sh, this script returns quast reports for the previous assembly done with SPADES

#module load singularity (this must be executed on the terminal)

mkdir -p logs

scratch_dir=$(echo $PWD | sed "s/\/data\/ucct\/bi\/scratch_tmp/\/scratch/g")

cat ../samples_id.txt | while read in; do echo "mkdir $in; srun --partition middle_idx --cpus-per-task 8 --mem 300G --chdir $scratch_dir --output logs/SPADES.${in}.%j.log singularity exec -B ${scratch_dir}/../../../ /data/ucct/bi/pipelines/singularity-images/depot.galaxyproject.org-singularity-quast-5.2.0--py39pl5321heaaa4ec_4.img quast.py  --min-contig 0 ../06-spades/${in}/contigs.fasta  ../06-spades/${in}/scaffolds.fasta -o ${in} --threads 8 &"; done > _01_quast.sh  
