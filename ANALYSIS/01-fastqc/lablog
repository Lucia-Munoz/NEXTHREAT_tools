#Executing this lablog will create the script _01_rawfastqc.sh, executing this script will create two HTML FASTQC files per sample one for the forward (R1) raw reads fastq and another for the reverse (R2) raw reads fastq

# module load singularity (this must me executed on the terminal)

#Create the logs directory

mkdir logs

#Direct the execution to the scratch directory

scratch_dir=$(echo $PWD | sed "s/\/data\/ucct\/bi\/scratch_tmp/\/scratch/g")

# The fastQC command

cat ../samples_id.txt | while read in; do echo "mkdir $in; srun --partition short_idx --cpus-per-task 8 --chdir $scratch_dir --output logs/FASTQC.${in}.%j.log singularity exec -B ${scratch_dir}/../../../ -B /srv/fastq_repo/ /data/ucct/bi/pipelines/singularity-images/fastqc:0.11.9--hdfd78af_1 fastqc -o ${scratch_dir}/$in -t 8 ${scratch_dir}/../00-reads/"$in"_R1.fastq.gz ${scratch_dir}/../00-reads/"$in"_R2.fastq.gz &"; done > _01_rawfastqc.sh
